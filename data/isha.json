r spacer-block sized vsize-1\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/6c7122d5-e209-4711-95b9-06f0c105ccea_621/website.components.spacer.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/6c7122d5-e209-4711-95b9-06f0c105ccea_621/website.components.spacer.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.spacer\" id=\"block-27ebb5a8792df76c740d\"><div class=\"sqs-block-content\">&nbsp;</div></div></div><div class=\"col sqs-col-6 span-6\"><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-spacer spacer-block sized vsize-1\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/6c7122d5-e209-4711-95b9-06f0c105ccea_621/website.components.spacer.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/6c7122d5-e209-4711-95b9-06f0c105ccea_621/website.components.spacer.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.spacer\" id=\"block-3d293a96ef897cbba0b3\"><div class=\"sqs-block-content\">&nbsp;</div></div><div class=\"sqs-block html-block sqs-block-html\" data-block-type=\"2\" data-sqsp-block=\"text\" id=\"block-8b88a212828fd0611422\"><div class=\"sqs-block-content\">\n\n<div class=\"sqs-html-content\" data-sqsp-text-block-content>\n  <h3 style=\"white-space:pre-wrap;\">Mision</h3><p class=\"\" style=\"white-space:pre-wrap;\">Enseñar ha las mujeres ha amar y respetar a sus familias, siendo forjadas por el poder de la palabra.</p><p class=\"\" data-rte-preserve-empty=\"true\" style=\"white-space:pre-wrap;\"></p><h3 style=\"white-space:pre-wrap;\">Vision</h3><p class=\"\" style=\"white-space:pre-wrap;\">Tocar la vida de miles de mujeres que necesitan esperanza y ser siempre un legado de bendición. </p><ul data-rte-list=\"default\"><li><p class=\"\" style=\"white-space:pre-wrap;\">1o. Para el Reino De Dios</p></li><li><p class=\"\" style=\"white-space:pre-wrap;\">2o. Para todos los que conozcan una ISHA</p></li></ul><p class=\"\" data-rte-preserve-empty=\"true\" style=\"white-space:pre-wrap;\"></p>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-spacer spacer-block sized vsize-1\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/6c7122d5-e209-4711-95b9-06f0c105ccea_621/website.components.spacer.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/6c7122d5-e209-4711-95b9-06f0c105ccea_621/website.components.spacer.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.spacer\" id=\"block-fbd9bd62f0f5ea67f007\"><div class=\"sqs-block-content\">&nbsp;</div></div><div class=\"sqs-block html-block sqs-block-html\" data-block-type=\"2\" data-sqsp-block=\"text\" id=\"block-yui_3_17_2_1_1570679785771_25682\"><div class=\"sqs-block-content\">\n\n<div class=\"sqs-html-content\" data-sqsp-text-block-content>\n  <pre style=\"text-align:center;\"><code>Asegurate de seguirnos en las redes sociales!!</code></pre>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n</div></div><div class=\"sqs-block socialaccountlinks-v2-block sqs-block-socialaccountlinks-v2\" data-block-type=\"54\" data-sqsp-block=\"social-links\" id=\"block-40799fb59407feabef17\"><div class=\"sqs-block-content\">\n\n\n\n<div class=\"sqs-svg-icon--outer social-icon-alignment-center social-icons-color-standard social-icons-size-extra-large social-icons-shape-circle social-icons-style-border\" >\n  <style>\n    #block-40799fb59407feabe